{
  "name": "@eldrex/vite",
  "version": "1.0.2",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Vite plugin for DevDiff — automatically runs changelog generation on build",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "prettier --check src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eldrex/core": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EldrexDelosReyesBula/devdiff.git",
    "directory": "packages/vite-plugin"
  },
  "keywords": [
    "vite-plugin",
    "changelog",
    "devdiff"
  ],
  "author": "Eldrex Delos Reyes Bula <eldrexdelosreyesbula@gmail.com>",
  "license": "MIT"
}
