{
  "name": "@eldrex/core",
  "version": "1.0.0",
  "description": "Core engine for DevDiff — intelligent, privacy-first changelog generation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "prettier --check src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "zod": "^3.23.0",
    "cosmiconfig": "^9.0.0",
    "typescript": "^5.5.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EldrexDelosReyesBula/devdiff.git",
    "directory": "packages/core"
  },
  "keywords": [
    "changelog",
    "git-diff",
    "ai",
    "developer-tools",
    "privacy",
    "local-first",
    "byoai"
  ],
  "author": "Eldrex Delos Reyes Bula <eldrexdelosreyesbula@gmail.com>",
  "license": "MIT"
}
