{
  "name": "devdiff",
  "displayName": "DevDiff",
  "description": "Privacy-first, BYOAI inline changelog intelligence for VS Code",
  "version": "1.0.3",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "publisher": "eldrex",
  "icon": "asset/devdiff.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:devdiff.showChangelog",
    "onCommand:devdiff.explainChanges"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "compile": "tsup",
    "watch": "tsup --watch",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@eldrex/core": "workspace:*",
    "@types/vscode": "^1.85.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "devdiff.showChangelog",
        "title": "DevDiff: Show Changelog"
      },
      {
        "command": "devdiff.explainChanges",
        "title": "DevDiff: Explain Staged Changes"
      },
      {
        "command": "devdiff.toggleWatch",
        "title": "DevDiff: Toggle Auto-Watch"
      },
      {
        "command": "devdiff.showOutput",
        "title": "DevDiff: Show Output Panel"
      }
    ],
    "configuration": {
      "title": "DevDiff",
      "properties": {
        "devdiff.autoGenerate": {
          "type": "boolean",
          "default": false,
          "description": "Auto-generate explanations when changes are staged"
        },
        "devdiff.persona": {
          "type": "string",
          "default": "developer",
          "enum": [
            "developer",
            "ceo",
            "educator",
            "pm",
            "compliance"
          ],
          "description": "AI persona for explanations"
        },
        "devdiff.showGutterAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Show inline annotations in the editor gutter"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EldrexDelosReyesBula/devdiff.git",
    "directory": "packages/vscode"
  },
  "author": "Eldrex Delos Reyes Bula <eldrexdelosreyesbula@gmail.com>",
  "license": "MIT"
}
