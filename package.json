{
  "name": "devdiff-monorepo",
  "version": "1.0.2",
  "private": true,
  "description": "Privacy-first, BYOAI changelog intelligence for developers",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "release": "turbo build && changeset publish",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitepress": "^1.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EldrexDelosReyesBula/devdiff.git"
  },
  "bugs": {
    "url": "https://github.com/EldrexDelosReyesBula/devdiff/issues"
  },
  "homepage": "https://github.com/EldrexDelosReyesBula/devdiff",
  "keywords": [
    "changelog",
    "git",
    "ai",
    "developer-tools",
    "privacy",
    "local-first",
    "byoai",
    "ollama",
    "open-source"
  ],
  "author": "Eldrex Delos Reyes Bula <eldrexdelosreyesbula@gmail.com>",
  "license": "MIT"
}
